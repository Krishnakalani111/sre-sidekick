# ============================================================
# SRE Sidekick — environment
# Copy to .env and fill in. Everything runs in MOCK mode with
# no keys set, so you can develop the whole pipeline offline.
# ============================================================

# ---- Data source mode ----
# true  = fake-mcp serves canned fixtures (no SigNoz needed)
# false = fake-mcp proxies the REAL local SigNoz (needs SIGNOZ_API_KEY)
USE_FAKE_MCP=true

# ---- SigNoz (local, running via docker) ----
SIGNOZ_BASE_URL=http://localhost:8080
# Create in SigNoz UI -> Settings -> API Keys. Required for LIVE data
# (v3/v4/v5 query_range endpoints return 401 without it).
SIGNOZ_API_KEY=

# ---- MCP ----
# URL the backend's mcp-client connects to. Points at fake-mcp by default;
# swap to the real SigNoz MCP server later.
MCP_SERVER_URL=http://localhost:8787/mcp
FAKE_MCP_PORT=8787

# ---- LLM for RCA (pick whichever is free) ----
# Provider auto-selected: gemini if GEMINI_API_KEY set, else grok if XAI_API_KEY
# set, else a deterministic MOCK client (no key needed).
LLM_PROVIDER=auto            # auto | gemini | grok | mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
XAI_API_KEY=
GROK_MODEL=grok-2-latest

# ---- Backend ----
BACKEND_PORT=3000
INVESTIGATION_MAX_STEPS=6
LOG_LEVEL=info
